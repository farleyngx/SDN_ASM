<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><title>Create New Question</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light py-4">
    <div class="container">
        <a href="/questions" class="btn btn-outline-secondary mb-3">&larr; Return</a>
        
        <h2 class="h3 text-dark mb-4">Create New Question</h2>

        <form action="/questions/create" method="POST">
            <div class="mb-3">
                <label class="form-label fw-semibold">Question Text</label>
                <input type="text" name="text" required class="form-control">
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Options (comma seperated)</label>
                <input type="text" name="options" required class="form-control">
            <div class="mb-3">
                <label class="form-label fw-semibold">Correct Answer Index</label>
                <input type="number" name="correctAnswerIndex" min="0" required class="form-control">
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Keywords (comma seperated)</label>
                <input type="text" name="keywords" class="form-control">
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create</button>
            </div>
        </form>
    </div>
</body>
</html>