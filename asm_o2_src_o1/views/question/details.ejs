<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><title>Chi tiết câu hỏi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light py-4">
    <div class="container">
        <a href="/questions" class="btn btn-outline-secondary mb-5">&larr; Return</a>
        <h2 class="text-xl font-weight-bold"><%= questions.text %></h2>
        <div class="row row-cols-1">
            <div class="d-flex align-content-center p-1 border">
                <p class="text-sm">
                    <%= questions.options.map((opt, idx) => idx === questions.correctAnswerIndex ? `${opt} (correct)` : opt).join(', ') %>
                </p>
            </div>
        </div>
         <a href="/questions/edit/<%= questions._id %>" class="mt-3 btn btn-warning">Edit Question</a>
    </div>
   
</body>
</html>