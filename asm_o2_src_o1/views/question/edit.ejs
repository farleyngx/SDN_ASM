<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Question</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light py-4">
    <div class="container">
        <a href="/questions" class="btn btn-outline-secondary mb-3">&larr; Return</a>

        <h2 class="h3 text-dark mb-4">Edit Question</h2>

        <form action="/questions/update/<%= question._id %>?_method=PUT" method="POST">
            <div class="mb-3">
                <label class="form-label fw-semibold">Question Text</label>
                <input type="text" name="text" value="<%= question.text %>" required class="form-control">
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Options (comma seperated)</label>
                <input type="text" name="options" value="<%= question.options.join(', ') %>" required class="form-control">
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Correct Answer Index</label>
                <input type="number" name="correctAnswerIndex" value="<%= question.correctAnswerIndex %>" min="0" required class="form-control">
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Keywords (comma seperated)</label>
                <input type="text" name="keywords" value="<%= question.keywords ? question.keywords.join(', ') : '' %>" class="form-control">
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Update</button>
            </div>
        </form>
    </div>
</body>
</html>